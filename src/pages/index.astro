---
import Layout from '../layouts/Page.astro';
import { Container, Button, FeatureCard } from '@components/odyssey-theme';
---

<Layout>
  <Container>
    <div class="py-24 md:py-32 flex flex-col items-center text-center">
      <h1 class="text-5xl md:text-7xl font-semibold tracking-tight mb-6 text-[#1d1d1f]">
        Healthcare, <br/> Delivered to You.
      </h1>
      <p class="text-xl md:text-2xl text-gray-500 max-w-2xl mb-10 font-light">
        Premium medical support and specialized care outside the hospital environment.
      </p>
      <div class="flex gap-4">
        <Button href="/services">Our Services</Button>
        <Button href="/company/contact" outlined>Get in Touch</Button>
      </div>
    </div>
  </Container>

  <div class="bg-[#f5f5f7] py-20">
    <Container>
      <h2 class="text-3xl font-semibold text-center mb-12">Our Specialized Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <FeatureCard title="Doctor & Nurse Visits" description="Professional clinical care in the comfort of your home." />
        <FeatureCard title="Ground Ambulance" description="24/7 emergency and non-emergency medical transport." />
        <FeatureCard title="Equipment Rental" description="High-quality medical tools for home recovery." />
        <FeatureCard title="Air Escorts" description="Safe medical transit for international or long-distance travel." />
        <FeatureCard title="Palliative Care" description="Compassionate support for chronic or terminal conditions." />
      </div>
    </Container>
  </div>
</Layout>
