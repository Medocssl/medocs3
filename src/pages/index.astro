---
import Layout from '../layouts/Page.astro';
import { Container, Button, FeatureCard, TextSection } from '@components/odyssey-theme';
---

<Layout>
  <Container>
    <div class="py-20 md:py-32 flex flex-col items-center text-center">
      <h1 class="text-5xl md:text-7xl font-semibold tracking-tight mb-6 text-[#1d1d1f]">
        Healthcare, <br/> Delivered to You.
      </h1>
      <p class="text-xl md:text-2xl text-gray-500 max-w-2xl mb-10 font-light">
        Experience premium, reliable medical support outside the traditional hospital environment.
      </p>
      <div class="flex gap-4">
        <Button href="/services" customIcon>Our Services</Button>
        <Button href="/company/contact" outlined>Contact Us</Button>
      </div>
    </div>
  </Container>

  <Container>
    <img 
      src="https://images.unsplash.com/photo-1516549655169-df83a0774514?auto=format&fit=crop&w=1200&q=80" 
      alt="Medical Professionals" 
      class="w-full h-[400px] object-cover rounded-2xl mb-20 shadow-sm"
    />
  </Container>

  <div class="bg-[#f5f5f7] py-20">
    <Container>
      <h2 class="text-3xl font-semibold text-center mb-12 tracking-wide">Premium Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <FeatureCard 
          title="Nurse Home Visits" 
          description="Compassionate nursing care delivered directly to your home for maximum comfort."
        />
        <FeatureCard 
          title="Ground Ambulance" 
          description="Rapid, reliable emergency and non-emergency medical transport."
        />
        <FeatureCard 
          title="Equipment Rental" 
          description="High-quality medical equipment available to support recovery at home."
        />
      </div>
    </Container>
  </div>
</Layout>
