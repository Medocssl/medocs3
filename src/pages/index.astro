---
import { Container, FeatureCard } from '@components/odyssey-theme';
import Layout from '../layouts/Page.astro';
import HomeHeroSection from '../components/sections/heros/HomeHeroSection.astro';
---

<Layout>
  <HomeHeroSection />

  <Container>
    <div class="py-16">
      <h2 class="text-3xl font-light text-center mb-12 tracking-wide text-gray-900">Our Premium Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        
        <FeatureCard 
          title="Nurse Home Visits" 
          description="Professional, compassionate nursing care delivered directly to your home for maximum comfort and convenience."
        />
        
        <FeatureCard 
          title="Ground Ambulance" 
          description="Rapid, reliable emergency and non-emergency medical transport with state-of-the-art life support equipment."
        />
        
        <FeatureCard 
          title="Equipment Rental" 
          description="High-quality medical equipment available for short or long-term rental to support recovery at home."
        />

      </div>
    </div>
  </Container>
</Layout>
