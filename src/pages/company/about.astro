---
import Layout from '../../layouts/Page.astro';
import { Container, TextSection } from '@components/odyssey-theme';
---

<Layout>
  <Container>
    <TextSection narrow>
      <h1 class="font-light tracking-tight text-4xl mb-6">About MEDOCS</h1>
      <p class="text-lg text-gray-600 leading-relaxed mb-6">
        MEDOCS Health Services (Pvt) Ltd was established with a singular vision: to bring exceptional, reliable healthcare directly to the community. Founded by Dr. Prageeth Witharana, our institution prioritizes patient well-being through accessible, professional medical support outside the traditional hospital environment.
      </p>
      <p class="text-lg text-gray-600 leading-relaxed">
        From emergency transport to daily home nursing, we adhere to the highest clinical standards, ensuring peace of mind for you and your loved ones.
      </p>
    </TextSection>
  </Container>
</Layout>
