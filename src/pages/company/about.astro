---
import Layout from '../../layouts/Page.astro';
import { Container, TextSection } from '@components/odyssey-theme';
---

<Layout>
  <Container>
    <div class="py-20 flex flex-col items-center">
      <TextSection narrow>
        <h1 class="font-semibold tracking-tight text-4xl mb-8 text-center">About MEDOCS</h1>
        
        <img 
          src="https://images.unsplash.com/photo-1519494026892-80bbd2d6fd0d?auto=format&fit=crop&w=800&q=80" 
          alt="Hospital Environment" 
          class="w-full h-64 object-cover rounded-2xl mb-8 shadow-sm"
        />

        <p class="text-lg text-gray-600 leading-relaxed mb-6">
          MEDOCS Health Services (Pvt) Ltd was established with a singular vision: to bridge the gap between clinical excellence and home comfort. Founded by <strong>Dr. Prageeth Witharana</strong>, our institution prioritizes patient well-being through accessible, professional medical support.
        </p>
        <p class="text-lg text-gray-600 leading-relaxed mb-6">
          We understand that healing often happens best in a familiar environment. By bringing essential healthcare services—from emergency transport to daily nursing—directly to the community, we ensure peace of mind for our patients and their families.
        </p>
        <p class="text-lg text-gray-600 leading-relaxed">
          At MEDOCS, we are driven by clinical precision, compassionate care, and a commitment to modernizing how healthcare is delivered.
        </p>
      </TextSection>
    </div>
  </Container>
</Layout>
