---
import Layout from '../../layouts/Page.astro';
import { Container, TextSection } from '@components/odyssey-theme';
---

<Layout>
  <Container>
    <div class="py-20 flex flex-col items-center">
      <TextSection narrow>
        <h1 class="font-semibold tracking-tight text-4xl mb-8 text-center">About MEDOCS</h1>
        <p class="text-lg text-gray-600 leading-relaxed mb-6">
          MEDOCS Health Services (Pvt) Ltd was founded by <strong>Dr. Prageeth Witharana</strong> with a commitment to modernizing healthcare delivery. 
        </p>
        <p class="text-lg text-gray-600 leading-relaxed">
          We believe that healing is most effective in a familiar environment. Our mission is to provide the highest clinical standards of a hospital within the peace and comfort of your own home.
        </p>
      </TextSection>
    </div>
  </Container>
</Layout>
