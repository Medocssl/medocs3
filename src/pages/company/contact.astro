---
import Layout from '../../layouts/Page.astro';
import { Container, Button } from '@components/odyssey-theme';
---

<Layout>
  <Container>
    <div class="py-24 max-w-2xl mx-auto">
      <h1 class="text-4xl font-semibold tracking-tight text-center mb-12">Contact Us</h1>
      <div class="bg-[#f5f5f7] p-10 rounded-2xl">
        <p class="text-xl font-medium mb-4">Our Hotline</p>
        <p class="text-3xl font-bold text-[#005ccd] mb-8">+94 (0) XX XXX XXXX</p>
        <p class="text-xl font-medium mb-2">Email</p>
        <p class="text-lg text-gray-600 mb-8">info@medocs.lk</p>
        <Button href="mailto:info@medocs.lk" className="w-full justify-center">Send an Email</Button>
      </div>
    </div>
  </Container>
</Layout>
