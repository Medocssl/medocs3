---
import Layout from '../layouts/Page.astro';
import { Container, TextSection } from '@components/odyssey-theme';
---

<Layout>
  <Container>
    <div class="py-16">
      <h1 class="text-4xl font-semibold tracking-tight mb-12 text-center">Our Services</h1>
      
      <div class="flex flex-col md:flex-row gap-12 items-center mb-20">
        <div class="flex-1">
          <img src="https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&fit=crop&w=800&q=80" alt="Nurse Visit" class="rounded-2xl shadow-sm"/>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold mb-4">Nurse Home Visits</h2>
          <p class="text-gray-600 text-lg leading-relaxed">Our certified nursing staff provides daily care, post-operative support, and general health monitoring in the comfort and privacy of your own home. We bring the clinical standards of a hospital directly to your doorstep.</p>
        </div>
      </div>

      <div class="flex flex-col md:flex-row-reverse gap-12 items-center mb-20">
        <div class="flex-1">
          <img src="https://images.unsplash.com/photo-1587556637775-603125e9894e?auto=format&fit=crop&w=800&q=80" alt="Ambulance" class="rounded-2xl shadow-sm"/>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold mb-4">Ground Ambulance</h2>
          <p class="text-gray-600 text-lg leading-relaxed">Equipped with state-of-the-art life support systems, our fleet of ambulances is ready for both emergency response and scheduled patient transfers. Staffed by trained paramedics, we ensure safe and efficient transport.</p>
        </div>
      </div>

      <div class="flex flex-col md:flex-row gap-12 items-center">
        <div class="flex-1">
          <img src="https://images.unsplash.com/photo-1584515933487-779824d29309?auto=format&fit=crop&w=800&q=80" alt="Medical Equipment" class="rounded-2xl shadow-sm"/>
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-semibold mb-4">Equipment Rental</h2>
          <p class="text-gray-600 text-lg leading-relaxed">We provide a wide range of reliable medical equipment for short or long-term rental. From hospital beds to oxygen concentrators, we supply the tools necessary for proper home care and rehabilitation.</p>
        </div>
      </div>

    </div>
  </Container>
</Layout>
